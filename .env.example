# =============================================================
# SunForm-NestAI - 环境变量示例
# 复制本文件为 .env 并填入真实值：
#     cp .env.example .env
# .env 已在 .gitignore 中，不会进入版本控制
# =============================================================

# ---------- 服务端口 ----------
PORT=9528

# ---------- PostgreSQL 数据库（Sequelize + pgvector） ----------
# 首次使用前需要先建库；并执行：CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=please-change-me
DATABASE_NAME=sunform_nest

# 是否开启 Sequelize 自动同步表结构
# 首次部署可设为 true 完成建表，之后务必改回 false
DB_SYNC=false

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ---------- JWT 鉴权 ----------
# 至少 32 位随机字符串，可使用：openssl rand -hex 32
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ---------- 微信公众号（可选，未启用可不填） ----------
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_TOKEN=

# ---------- 文件管理服务（agent 附件上传） ----------
# 默认为空，不配置时文件上传/压缩功能不可用
# FILE_MANAGE_URL=
# FILE_MANAGE_KEY=

# ---------- AI 通用配置（语言模型：chat / completions） ----------
# 走 OpenAI 兼容协议：base_url 不要带 /chat/completions 后缀
# 默认对接 MiniMax，可改成任何兼容服务（OpenAI / DeepSeek / Moonshot / 自部署）
# AI_AGENT_API_KEY=
# AI_AGENT_BASE_URL=https://api.minimaxi.com/v1
# AI_AGENT_MODEL=MiniMax-M2.7

# ---------- AI 向量模型（Embedding 专用） ----------
# ⚠️ 向量接口协议跟 chat 不一样：请求体用 {texts, type}，返回 vectors（不是 {input} → data[].embedding）
#    文档：https://api.minimaxi.com/v1/embeddings
#    不配置时回退到 AI_AGENT_* 变量，但 key/base_url 必须跟模型匹配，否则会 401
# AI_EMBEDDING_API_KEY=
# AI_EMBEDDING_BASE_URL=https://api.minimaxi.com/v1
# AI_EMBEDDING_MODEL=embo-01

# ---------- AI TTS / 语音克隆（可选） ----------
# MiniMax 语音克隆 Key（与 Embedding 复用同一个也行）
# MINIMAX_API_KEY=

# ---------- 兼容旧版变量（可忽略，新代码已统一使用 AI_AGENT_*） ----------
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=
# COZE_API_KEY=
# COZE_BASE_URL=
